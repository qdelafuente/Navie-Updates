{
  "manifest_version": 3,
  "name": "Navie - Blackboard AI",
  "version": "0.4.5",
  "key": "",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "cookies",
    "sidePanel",
    "notifications",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://blackboard.ie.edu/*",
    "https://openrouter.ai/*",
    "https://ltitools.ie.edu/*",
    "https://iesurveys.bluera.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.min.js",
        "lib/pdf.worker.min.js",
        "pdfReadingOrder.js",
        "update.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Abrir Navie - Blackboard AI",
    "default_icon": {
      "16": "Logo.png",
      "48": "Logo.png",
      "128": "Logo.png"
    }
  },
  "icons": {
    "16": "Logo.png",
    "48": "Logo.png",
    "128": "Logo.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://blackboard.ie.edu/*"],
      "js": ["timeContext.js", "courseRegistry.js", "contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
